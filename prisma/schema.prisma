//   image String
// }

enum Role {
  USER
  ADMIN
}

enum ValveCategory {
  butterfly
  ball
  retention
  guillotine
  locks
  air
  special
}

enum ActuatorsSubcategory {
  manual
  neumatic
  electric
  electrohydarulic
}

enum AccesorySubcategory {
  neumatic
}