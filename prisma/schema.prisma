//   image String
// }

enum Role {
  USER
  ADMIN
}

enum ValveCategory {
  mariposas
  esfericas
  retencion
  guillotina_y_compuertas
  esclusas
  aire
  aplicaciones_especiales
}

enum ActuatorCategory {
  manual
  neumaticos
  electricos
  electrohidraulicos
}

enum AccesoryCategory {
  neumaticos
}